

{
  "version": 8,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-base",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "gcc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "debug",
      "inherits": [
        "debug-base",
        "clang"
      ]
    },
    {
      "name": "release",
      "inherits": [
        "release-base",
        "clang"
      ]
    },
    {
      "name": "debug-gcc",
      "binaryDir": "${sourceDir}/build/debug-gcc",
      "inherits": [
        "debug-base",
        "gcc"
      ]
    },
    {
      "name": "release-gcc",
      "binaryDir": "${sourceDir}/build/release-gcc",
      "inherits": [
        "release-base",
        "gcc"
      ]
    },
    {
      "name": "debug-msvc",
      "inherits": [
        "debug-base",
        "msvc"
      ],
      "binaryDir": "${sourceDir}/build/debug-msvc"
    },
    {
      "name": "release-msvc",
      "inherits": [
        "release-base",
        "msvc"
      ],
      "binaryDir": "${sourceDir}/build/release-msvc"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug-gcc",
      "configurePreset": "debug-gcc"
    },
    {
      "name": "release-gcc",
      "configurePreset": "release-gcc"
    },
    {
      "name": "debug-msvc",
      "configurePreset": "debug-msvc"
    },
    {
      "name": "release-msvc",
      "configurePreset": "release-msvc"
    }
  ]
}

